<Window x:Class="WPF_credit_depozite1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фінансовий помічник" Height="633" Width="1226"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#121212"/>
        <SolidColorBrush x:Key="MainText" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#888888"/>
        <SolidColorBrush x:Key="ControlBg" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3F51B5"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource MainText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="0,0,40,0"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <CheckBox x:Name="themeToggle" Content="Темна тема" 
                  Foreground="{DynamicResource MainText}"
                  HorizontalAlignment="Right" VerticalAlignment="Top" 
                  IsChecked="True" Click="ThemeToggle_Click"
                  Grid.Column="1" Margin="0,10,10,0" FontSize="14"/>

        <Label Grid.ColumnSpan="2" Content="Калькулятор кредита та депозита" 
               FontSize="34" FontWeight="ExtraBold" Foreground="{DynamicResource AccentColor}" 
               HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="52,10,0,0" Grid.ColumnSpan="2">
            <RadioButton x:Name="rbCredit" Content="Кредит" IsChecked="True"/>
            <RadioButton x:Name="rbDeposit" Content="Депозит"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="52,0,50,0">
            <Label Content="Сума (грн)" FontSize="18"/>
            <TextBox x:Name="tbAmount" Height="40" PreviewTextInput="NumberValidationTextBox" LostFocus="TextBox_FormatN2"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="52,0,50,0">
            <Label Content="Відсоток (% річних)" FontSize="18"/>
            <TextBox x:Name="tbPercent" Height="40" PreviewTextInput="NumberValidationTextBox" LostFocus="TextBox_FormatN2"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="52,0,50,0">
            <Label Content="Термін (місяці)" FontSize="18"/>
            <TextBox x:Name="tbMonths" Height="40" PreviewTextInput="NumberValidationTextBox"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="3" Margin="145,13,0,0">
            <Label x:Name="lblResult" Content="Результат" FontSize="22" Foreground="{DynamicResource SecondaryText}"/>
            <Label x:Name="lblResultNum" Content="0,00₴" FontSize="48" FontWeight="ExtraBold" Foreground="{DynamicResource AccentColor}" Margin="0,15,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="Зберегти" Style="{StaticResource ModernButtonStyle}" Width="180" Height="48" Margin="0,0,20,0" Click="btnSave_Click" Opacity="0.8"/>
            <Button Content="Розрахувати" Style="{StaticResource ModernButtonStyle}" Width="180" Height="48" Click="btnCalculate_Click"/>
        </StackPanel>
    </Grid>
</Window>